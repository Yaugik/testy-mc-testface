{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testy-mctestface.dev/schemas/vendor/v1/vendor.schema.json",
  "title": "Testy McTestface vendor configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "vendor", "server", "routing", "privacy"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "vendor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "contractVersion"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "displayName": { "type": "string", "minLength": 1 },
        "contractVersion": { "type": "string", "minLength": 1 }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basePath", "defaultContentType"],
      "properties": {
        "basePath": { "type": "string", "pattern": "^/" },
        "defaultContentType": { "type": "string", "minLength": 1 }
      }
    },
    "authentication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategies"],
      "properties": {
        "strategies": {
          "type": "array",
          "items": { "$ref": "#/$defs/authenticationStrategy" }
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unmatchedRequest"],
      "properties": {
        "unmatchedRequest": { "$ref": "#/$defs/response" }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture"],
      "properties": {
        "capture": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allow", "redactHeaders"],
          "properties": {
            "allow": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "enum": [
                  "method",
                  "path",
                  "queryKeys",
                  "selectedHeaders",
                  "bodyFingerprint",
                  "timing"
                ]
              }
            },
            "redactHeaders": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "duration": {
      "type": "string",
      "pattern": "^[0-9]+(?:ms|s|m)$"
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "contentType": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 },
        "delay": { "$ref": "#/$defs/duration" }
      }
    },
    "authenticationStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "source", "name", "validValues", "onFailure"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "type": { "enum": ["bearer", "api-key", "basic"] },
        "source": { "enum": ["header", "query"] },
        "name": { "type": "string", "minLength": 1 },
        "validValues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "onFailure": { "$ref": "#/$defs/response" }
      }
    }
  }
}
