{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testy-mctestface.dev/schemas/vendor-contract/v1/contract.schema.json",
  "title": "Testy McTestface vendor contract suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suiteId", "cases"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "suiteId": { "$ref": "#/$defs/id" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headers": { "$ref": "#/$defs/stringMap" },
        "query": { "$ref": "#/$defs/stringMap" },
        "requestTimeoutMs": { "type": "integer", "minimum": 1, "maximum": 120000 }
      }
    },
    "cases": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/case" } },
    "isolation": { "$ref": "#/$defs/isolation" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "stringMap": { "type": "object", "additionalProperties": { "type": "string" } },
    "jsonValue": {
      "oneOf": [
        { "type": ["string", "number", "boolean", "null"] },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/jsonValue" } }
      ]
    },
    "numericRange": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 }
      }
    },
    "countExpectation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "exact": { "type": "integer", "minimum": 0 },
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      },
      "allOf": [
        {
          "if": { "required": ["exact"] },
          "then": { "not": { "anyOf": [{ "required": ["min"] }, { "required": ["max"] }] } }
        }
      ]
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path"],
      "properties": {
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string", "pattern": "^/" },
        "headers": { "$ref": "#/$defs/stringMap" },
        "query": { "$ref": "#/$defs/stringMap" },
        "jsonBody": { "$ref": "#/$defs/jsonValue" },
        "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 120000 }
      }
    },
    "stepExpectation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "transportError": { "const": true },
        "matchedCase": { "$ref": "#/$defs/id" },
        "sequenceIndex": { "type": "integer", "minimum": 0 },
        "stateBefore": { "$ref": "#/$defs/id" },
        "stateAfter": { "$ref": "#/$defs/id" },
        "durationMs": { "$ref": "#/$defs/numericRange" }
      },
      "not": { "required": ["status", "transportError"] }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "request", "expect"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "request": { "$ref": "#/$defs/request" },
        "expect": { "$ref": "#/$defs/stepExpectation" }
      }
    },
    "callExpectation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "total": { "$ref": "#/$defs/countExpectation" },
        "byCase": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "$ref": "#/$defs/countExpectation" }
        },
        "orderedCases": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
        "absentCases": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "durationMs": { "$ref": "#/$defs/numericRange" },
        "retryIntervalMs": { "$ref": "#/$defs/numericRange" }
      }
    },
    "stateExpectation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "state": { "$ref": "#/$defs/id" },
        "stores": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "type": "object", "additionalProperties": { "$ref": "#/$defs/jsonValue" } }
        },
        "absentStoreKeys": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "caseExpectation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "state": { "$ref": "#/$defs/id" },
        "stores": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "type": "object", "additionalProperties": { "$ref": "#/$defs/jsonValue" } }
        },
        "absentStoreKeys": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        },
        "calls": { "$ref": "#/$defs/callExpectation" }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "steps"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "resetBefore": { "type": "boolean" },
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } },
        "expect": { "$ref": "#/$defs/caseExpectation" }
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "request", "expect", "mutated", "untouched"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "request": { "$ref": "#/$defs/request" },
        "expect": { "$ref": "#/$defs/stepExpectation" },
        "mutated": { "$ref": "#/$defs/stateExpectation" },
        "untouched": { "$ref": "#/$defs/stateExpectation" }
      }
    }
  }
}
