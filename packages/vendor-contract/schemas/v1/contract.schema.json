{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testy-mctestface.dev/schemas/vendor-contract/v1/contract.schema.json",
  "title": "Testy McTestface vendor contract suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suiteId", "cases"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "suiteId": { "$ref": "#/$defs/id" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headers": { "$ref": "#/$defs/stringMap" },
        "query": { "$ref": "#/$defs/stringMap" },
        "requestTimeoutMs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120000
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "jsonValue": {
      "oneOf": [
        { "type": ["string", "number", "boolean", "null"] },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path"],
      "properties": {
        "method": {
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "path": { "type": "string", "pattern": "^/" },
        "headers": { "$ref": "#/$defs/stringMap" },
        "query": { "$ref": "#/$defs/stringMap" },
        "jsonBody": { "$ref": "#/$defs/jsonValue" },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120000
        }
      }
    },
    "stepExpectation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "transportError": { "const": true },
        "matchedCase": { "$ref": "#/$defs/id" },
        "sequenceIndex": { "type": "integer", "minimum": 0 },
        "stateBefore": { "$ref": "#/$defs/id" },
        "stateAfter": { "$ref": "#/$defs/id" }
      },
      "not": { "required": ["status", "transportError"] }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "request", "expect"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "request": { "$ref": "#/$defs/request" },
        "expect": { "$ref": "#/$defs/stepExpectation" }
      }
    },
    "caseExpectation": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "state": { "$ref": "#/$defs/id" },
        "stores": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/id" },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/jsonValue" }
          }
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "steps"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "resetBefore": { "type": "boolean" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        },
        "expect": { "$ref": "#/$defs/caseExpectation" }
      }
    }
  }
}
