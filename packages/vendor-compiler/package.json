{
  "name": "@testy/vendor-compiler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "testy-vendor-compile": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm --filter @testy/vendor-schema build && pnpm --filter @testy/config-loader build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "pretest": "pnpm --filter @testy/vendor-schema build && pnpm --filter @testy/config-loader build",
    "test": "vitest run"
  },
  "dependencies": {
    "@testy/config-loader": "workspace:*",
    "@testy/vendor-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
