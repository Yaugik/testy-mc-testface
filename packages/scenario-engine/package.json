{
  "name": "@testy/scenario-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "testy-scenario": "./dist/cli.js"
  },
  "scripts": {
    "prebuild": "pnpm --filter @testy/shared-types build",
    "build": "tsc -p tsconfig.json && node scripts/copy-schemas.mjs",
    "pretypecheck": "pnpm run prebuild",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "pretest": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@testy/shared-types": "workspace:*",
    "ajv": "^8.0.0",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
