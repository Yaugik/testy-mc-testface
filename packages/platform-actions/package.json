{
  "name": "@testy/platform-actions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @testy/shared-types build && pnpm --filter @testy/scenario-engine build && pnpm --filter @testy/config-loader build && pnpm --filter @testy/vendor-compiler build && pnpm --filter @testy/vendor-runtime build && pnpm --filter @testy/browser-config build && pnpm --filter @testy/synthetic-site-host build && pnpm --filter @testy/browser-runner build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm run prebuild",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "pretest": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@testy/browser-config": "workspace:*",
    "@testy/browser-runner": "workspace:*",
    "@testy/browser-schema": "workspace:*",
    "@testy/config-loader": "workspace:*",
    "@testy/scenario-engine": "workspace:*",
    "@testy/shared-types": "workspace:*",
    "@testy/synthetic-site-host": "workspace:*",
    "@testy/vendor-compiler": "workspace:*",
    "@testy/vendor-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
